--- a/Telegram/SourceFiles/history/view/media/history_view_media.cpp
+++ b/Telegram/SourceFiles/history/view/media/history_view_media.cpp
@@ -30,6 +30,7 @@ https://github.com/telegramdesktop/tdesktop/blob/master/LEGAL
 #include "ui/painter.h"
 #include "ui/power_saving.h"
 #include "ui/text/text_utilities.h"
+#include "yukigram/settings/old_style_spoilers.h"
 #include "core/ui_integration.h"
 #include "styles/style_chat.h"
 #include "styles/style_chat_helpers.h"
@@ -352,6 +353,7 @@ void Media::fillImageSpoiler(
 		history()->owner().registerHeavyViewPart(_parent);
 	}
 	_parent->clearCustomEmojiRepaint();
+if (!Yukigram::Settings::OldStyleSpoilers->current()) {
 	const auto pausedSpoiler = context.paused
 		|| On(PowerSaving::kChatSpoiler);
 	Ui::FillSpoilerRect(
@@ -361,6 +363,24 @@ void Media::fillImageSpoiler(
 		Ui::DefaultImageSpoiler().frame(
 			spoiler->animation->index(context.now, pausedSpoiler)),
 		spoiler->cornerCache);
+} else {
+	const auto text = tr::lng_sr_message_spoiler(tr::now);
+	const auto font = st::defaultTextStyle.font;
+	const auto margin = 5;
+	const auto height = font->height;
+	const auto bottom = rect.bottom() - margin;
+	const auto top = bottom - height;
+	const auto left = rect.left() + margin;
+	const auto width = font->width(text);
+	const auto bgRect = QRect(left, top, width + 2 * margin, height);
+	const auto fgRect = QRect(left + margin, top, width + margin, height);
+	auto path = QPainterPath();
+	path.addRoundedRect(bgRect, 2, 2);
+	p.fillPath(path, Qt::black);
+	p.setPen(Qt::white);
+	p.setFont(font);
+	p.drawText(fgRect, text);
+}
 }
 
 void Media::drawSpoilerTag(
diff --git a/Telegram/SourceFiles/yukigram/settings/old_style_spoilers.cpp b/Telegram/SourceFiles/yukigram/settings/old_style_spoilers.cpp
new file mode 100644
index 0000000000..9a46e62048
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/old_style_spoilers.cpp
@@ -0,0 +1,20 @@
+#include "yukigram/settings/old_style_spoilers.h"
+#include "yukigram/options.h"
+
+namespace Ui {
+extern bool Yukigram_OldStyleSpoilers;
+}
+
+namespace Yukigram::Settings {
+
+rpl::variable<bool> *OldStyleSpoilers = Yukigram::Options::make(kOptionOldStyleSpoilers, {
+	.name = "Old-style spoilers (without mess)",
+	.keywords = { u"yukigram"_q, u"spoilers"_q, u"mess"_q },
+	.category = "style",
+}, [](bool value) {
+	Ui::Yukigram_OldStyleSpoilers = value;
+});
+
+const char kOptionOldStyleSpoilers[] = "old-style-spoilers";
+
+}
diff --git a/Telegram/SourceFiles/yukigram/settings/old_style_spoilers.h b/Telegram/SourceFiles/yukigram/settings/old_style_spoilers.h
new file mode 100644
index 0000000000..4a84202013
--- /dev/null
+++ b/Telegram/SourceFiles/yukigram/settings/old_style_spoilers.h
@@ -0,0 +1,5 @@
+#include "rpl/rpl.h"
+namespace Yukigram::Settings {
+extern rpl::variable<bool> *OldStyleSpoilers;
+extern const char kOptionOldStyleSpoilers[];
+}
diff --git a/Telegram/lib_ui/ui/effects/spoiler_mess.cpp b/Telegram/lib_ui/ui/effects/spoiler_mess.cpp
index d4413de547..090b204754 100644
--- a/Telegram/lib_ui/ui/effects/spoiler_mess.cpp
+++ b/Telegram/lib_ui/ui/effects/spoiler_mess.cpp
@@ -10,6 +10,7 @@
 #include "ui/image/image_prepare.h"
 #include "ui/painter.h"
 #include "ui/integration.h"
+#include "styles/style_basic.h"
 #include "base/random.h"
 #include "base/flags.h"
 
@@ -428,14 +429,30 @@ SpoilerMessCached GenerateSpoilerMess(
 		size);
 }
 
+extern bool Yukigram_OldStyleSpoilers;
+bool Yukigram_OldStyleSpoilers = false;
+
+void FillSpoilerRectEx(QPainter &p, QRect rect, const SpoilerMessFrame &frame, QPoint originShift, bool round = false);
+
 void FillSpoilerRect(
 		QPainter &p,
 		QRect rect,
 		const SpoilerMessFrame &frame,
 		QPoint originShift) {
+	return FillSpoilerRectEx(p, rect, frame, originShift, true);
+}
+
+void FillSpoilerRectEx(QPainter &p, QRect rect, const SpoilerMessFrame &frame, QPoint originShift, bool round) {
 	if (rect.isEmpty()) {
 		return;
 	}
+	if (Yukigram_OldStyleSpoilers) {
+		const auto radius = round ? 2 : 0;
+		auto path = QPainterPath();
+		path.addRoundedRect(rect, radius, radius);
+		p.fillPath(path, st::defaultTextPalette.spoilerFg->c);
+		return;
+	}
 	const auto &image = *frame.image;
 	const auto source = frame.source;
 	const auto ratio = style::DevicePixelRatio();
@@ -520,7 +537,7 @@ void FillSpoilerRect(
 		&& (!mask.p[kTopRight] || mask.p[kTopRight]->isNull())
 		&& (!mask.p[kBottomLeft] || mask.p[kBottomLeft]->isNull())
 		&& (!mask.p[kBottomRight] || mask.p[kBottomRight]->isNull())) {
-		FillSpoilerRect(p, rect, frame, originShift);
+		FillSpoilerRectEx(p, rect, frame, originShift);
 		return;
 	}
 	const auto ratio = style::DevicePixelRatio();
@@ -532,7 +549,7 @@ void FillSpoilerRect(
 		return std::max(cornerSize(left), cornerSize(right));
 	};
 	const auto fillBg = [&](QRect part) {
-		FillSpoilerRect(
+		FillSpoilerRectEx(
 			p,
 			part.translated(rect.topLeft()),
 			frame,
@@ -556,7 +573,7 @@ void FillSpoilerRect(
 		const auto target = QRect(QPoint(), size);
 		auto q = QPainter(&cornerCache);
 		q.setCompositionMode(QPainter::CompositionMode_Source);
-		FillSpoilerRect(
+		FillSpoilerRectEx(
 			q,
 			target,
 			frame,
